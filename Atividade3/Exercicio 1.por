programa  
{  
    funcao inicio()  
    {  
                        
        inteiro dia  
  
        escreva ("Digite um dia: ")  
        leia (dia)  
          
        se (dia >= 7 e dia <= 30)  
        {  
            escreva ("semana 1")  
        }  
        senao  
        {  
            escreva ("semana 2")  
        }  
          
    }  
}  